@model FixMyCar.Web.Models.Offer

@{
    ViewData["Title"] = "Offer Details";
}

<h2>Offer Details</h2>
<div class="card p-3">

    <h4>@Model.Price $</h4>

    <p>@Model.Message</p>

    <hr />

    <p><b>Post:</b> @Model.Post?.Title</p>
    <p><b>UserId:</b> @Model.UserId</p>
    <p><b>Created:</b> @Model.CreatedAt</p>

</div>
<a asp-controller="Post"
     asp-action="Details"
     asp-route-id="@Model.PostId"
     class="btn btn-secondary mt-3">
     Back
</a>
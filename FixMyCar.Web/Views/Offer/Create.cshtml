@model FixMyCar.Web.ViewModels.OfferCreateViewModel
@{
    ViewData["Title"] = "Create Offer";
}

<h2>Create Offer</h2>
<form asp-action="Create" method="post">
    <input type="hidden" name="postId" value="@ViewBag.PostId" />
    <div class="mb-3"><label asp-for="Price"></label><input asp-for="Price" class="form-control" /><span asp-validation-for="Price" class="text-danger small"></span></div>
    <div class="mb-3"><label asp-for="Message"></label><textarea asp-for="Message" class="form-control"></textarea><span asp-validation-for="Message" class="text-danger small"></span></div>
    <button type="submit" class="btn btn-success">Send Offer</button>
</form>
<a asp-controller="Post" asp-action="Details" asp-route-id="@ViewBag.PostId" class="btn btn-secondary mt-2">Back</a>

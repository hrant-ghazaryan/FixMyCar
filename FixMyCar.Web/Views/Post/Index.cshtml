@model List<FixMyCar.Web.Models.Post>

@{
    ViewData["Title"] = "Հարցումներ";
}

<section class="posts-page container py-4">
    <header class="posts-page-heading">
        <div>
            <p class="eyebrow">FixMyCar marketplace</p>
            <h1>Բոլոր հարցումները</h1>
            <p>Գտեք ձեզ հարմար աշխատանքը և ուղարկեք առաջարկ։</p>
        </div>
        <a asp-action="Create" class="btn request-publish">+ Տեղադրել հարցում</a>
    </header>

    @if (!Model.Any())
    {
        <div class="posts-empty">
            <h2>Այս պահին հարցումներ չկան</h2>
            <p>Դուք կարող եք առաջինը տեղադրել ձեր մեքենայի խնդիրը։</p>
            <a asp-action="Create" class="btn auth-submit">Տեղադրել հարցում</a>
        </div>
    }
    else
    {
        <div class="posts-feed">
            @foreach (var post in Model)
            {
                var mainImage = post.Media?.FirstOrDefault(m => m.IsMain) ?? post.Media?.FirstOrDefault();
                <article class="marketplace-post-card">
                    @if (mainImage != null)
                    {
                        <a asp-action="Details" asp-route-id="@post.Id" class="marketplace-post-image-link">
                            <img src="@Url.Content(mainImage.FilePath)" class="marketplace-post-image" alt="@post.Title" />
                        </a>
                    }
                    <div class="marketplace-post-body">
                        <div class="marketplace-post-top">
                            <div>
                                <span class="post-category">@post.Category?.Name</span>
                                <h2>@post.Title</h2>
                            </div>
                            <time>@post.CreatedAt.ToString("dd MMM, HH:mm")</time>
                        </div>
                        <p>@(post.Description.Length > 160 ? post.Description[..160] + "..." : post.Description)</p>
                        <footer>
                            <span class="marketplace-post-location">@post.City</span>
                            <div class="marketplace-post-actions">
                                <a asp-action="Details" asp-route-id="@post.Id" class="btn post-secondary-action">Դիտել</a>
                                <a asp-controller="Offer" asp-action="Create" asp-route-postId="@post.Id" class="btn post-primary-action">Առաջարկել գին</a>
                            </div>
                        </footer>
                    </div>
                </article>
            }
        </div>
    }
</section>

@model FixMyCar.Web.Models.Post

@{
    ViewData["Title"] = "Delete Post";
}

<h2 class="mb-3">Delete Post</h2>

<div class="alert alert-warning">
    Are you sure you want to delete <b>@Model.Title</b>?
</div>

<div class="card p-3 mb-3">

    <p><b>Title:</b> @Model.Title</p>
    <p><b>Description:</b> @Model.Description</p>
    <p><b>City:</b> @Model.City</p>
    <p><b>Category:</b> @Model.Category?.Name</p>
    <p><b>Created:</b> @Model.CreatedAt</p>

</div>

<form asp-action="Delete" method="post">

    <!-- 🔐 important security -->
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger"
            onclick="return confirm('Are you sure you want to delete this post?');">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>
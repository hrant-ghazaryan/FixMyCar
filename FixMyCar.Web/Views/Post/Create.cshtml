@model FixMyCar.Web.ViewModels.PostCreateViewModel

@{
    ViewData["Title"] = "Տեղադրել հարցում";
}

<section class="request-page container py-4">
    <div class="request-heading">
        <p class="eyebrow">Նոր հարցում</p>
        <h1>Ի՞նչ խնդիր ունի մեքենան</h1>
        <p>Նկարագրեք խնդիրը հնարավորինս պարզ, որպեսզի մասնագետները ճիշտ առաջարկ ուղարկեն։</p>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="request-form">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <section class="request-form-card">
            <div class="request-card-heading">
                <span class="request-step">1</span>
                <div>
                    <h2>Հիմնական տեղեկություն</h2>
                    <p>Ասեք՝ ինչ աշխատանքի կարիք ունի մեքենան։</p>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-md-8">
                    <label asp-for="Title" class="form-label">Հարցման վերնագիր</label>
                    <input asp-for="Title" class="form-control" placeholder="Օր.` Շարժիչից ձայն է գալիս" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="City" class="form-label">Քաղաք</label>
                    <input asp-for="City" class="form-control" placeholder="Օր.` Երևան" />
                    <span asp-validation-for="City" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="CategoryId" class="form-label">Ծառայության կատեգորիա</label>
                    <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                        <option value="">Ընտրեք կատեգորիան</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>
        </section>

        <section class="request-form-card">
            <div class="request-card-heading">
                <span class="request-step">2</span>
                <div>
                    <h2>Նկարագրեք խնդիրը</h2>
                    <p>Նշեք մեքենայի մոդելը, խնդրի ախտանիշները և կարևոր մանրամասները։</p>
                </div>
            </div>

            <label asp-for="Description" class="form-label">Մանրամասն նկարագրություն</label>
            <textarea asp-for="Description" class="form-control request-description" rows="6" placeholder="Օր.` Toyota Camry 2015. Շարժիչը սառը վիճակում աշխատելիս ձայն է հանում…"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </section>

        <section class="request-form-card">
            <div class="request-card-heading">
                <span class="request-step">3</span>
                <div>
                    <h2>Ավելացրեք նկարներ</h2>
                    <p>Նկարներն օգնում են մասնագետին արագ հասկանալ խնդիրը։</p>
                </div>
            </div>

            <label class="upload-area" for="Files">
                <span class="upload-icon">+</span>
                <span><strong>Ընտրել նկարներ</strong><small>JPG, PNG կամ WebP · մինչև 10 նկար, յուրաքանչյուրը մինչև 5 ՄԲ</small></span>
                <input asp-for="Files" id="Files" type="file" multiple accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
            </label>
            <span asp-validation-for="Files" class="text-danger small"></span>
        </section>

        <div class="request-actions">
            <a asp-action="Index" class="btn request-cancel">Չեղարկել</a>
            <button type="submit" class="btn request-publish">Տեղադրել հարցումը</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model FixMyCar.Web.Models.Post
@using FixMyCar.Web.Models

@{
    ViewData["Title"] = "Post Details";
    var offers = ViewBag.Offers as List<FixMyCar.Web.Models.Offer> ?? new();
}

<div class="container mt-4">

    <!-- POST HEADER -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <h2 class="mb-2">@Model.Title</h2>

            <p class="text-muted mb-1">
                📍 @Model.City
            </p>

            <p class="mb-2">
                🏷 @Model.Category?.Name
            </p>

            <p class="mt-3">
                @Model.Description
            </p>

        </div>
    </div>

    <!-- IMAGES -->
    @if (Model.Media != null && Model.Media.Any())
    {
        <h4 class="mt-4">Photos</h4>

        <div class="row">
            @foreach (var media in Model.Media.OrderBy(m => m.Order))
            {
                @if (media.Type == MediaType.Image)
                {
                    <div class="col-md-4 mb-3">
                        <img src="@media.FilePath"
                             alt="Post image"
                             class="img-fluid rounded shadow-sm" />
                    </div>
                }
            }
        </div>
    }

    <!-- OFFERS -->
    <div class="d-flex justify-content-between align-items-center mb-2">

        <h4>Offers</h4>

        <a asp-controller="Offer"
               asp-action="Create"
               asp-route-postId="@Model.Id"
               class="btn btn-success btn-sm">
            + Make Offer
        </a>

    </div>

    @if (offers.Any())
    {
        @foreach (var offer in offers)
        {
            <div class="card mb-2 shadow-sm border-0">

                <div class="card-body d-flex justify-content-between">

                    <div>
                        <h5 class="mb-1 text-success">
                            $@offer.Price
                        </h5>

                        <p class="mb-0">
                            @offer.Message
                        </p>
                    </div>

                    <div class="text-end">

                        <small class="text-muted d-block">
                            User: @offer.UserId
                        </small>

                        <a asp-controller="Offer"
                               asp-action="Details"
                               asp-route-id="@offer.Id"
                               class="btn btn-sm btn-info mt-2">
                            View
                        </a>

                    </div>

                </div>

            </div>
        }
    }
    else
    {
        <div class="alert alert-info">
            No offers yet. Be the first to make one!
        </div>
    }

</div>
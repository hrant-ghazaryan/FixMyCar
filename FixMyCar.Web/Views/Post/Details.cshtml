@model FixMyCar.Web.Models.Post
@using FixMyCar.Web.Models

@{
    ViewData["Title"] = "Post Details";
    var offers = ViewBag.Offers as List<Offer> ?? new List<Offer>();
}

<div class="container py-4">


    <!-- POST CARD -->
    <div class="card shadow-sm border-0 mb-4">

        <div class="card-body">

            <h2 class="fw-bold mb-2">
                @Model.Title
            </h2>

            <div class="text-muted mb-2">
                📍 @Model.City
            </div>

            <div class="mb-2">
                🏷 @Model.Category?.Name
            </div>

            <p class="mt-3">
                @Model.Description
            </p>

        </div>

    </div>

    <!-- IMAGES SECTION -->
    @if (Model.Media != null && Model.Media.Any())
    {
        <h4 class="mb-3">Photos</h4>

        <div class="row">

            @foreach (var media in Model.Media.OrderBy(m => m.Order))
            {
                if (media.Type == MediaType.Image)
                {
                    <div class="col-md-4 mb-3">

                        <img src="@Url.Content(media.FilePath)"
                             class="img-fluid rounded shadow-sm"
                             style="height:200px; object-fit:cover;" />

                    </div>
                }
            }

        </div>
    }

    <!-- OFFERS SECTION -->
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">

        <h4>Offers</h4>

        <a asp-controller="Offer"
               asp-action="Create"
               asp-route-postId="@Model.Id"
               class="btn btn-success btn-sm">
            + Make Offer
        </a>

    </div>

    @if (offers.Any())
    {
        @foreach (var offer in offers)
        {
            <div class="card mb-2 border-0 shadow-sm">

                <div class="card-body d-flex justify-content-between">

                    <div>

                        <h5 class="text-success mb-1">
                            $@offer.Price
                        </h5>

                        <p class="mb-0">
                            @offer.Message
                        </p>

                    </div>

                    <div class="text-end">

                        <small class="text-muted d-block">
                            User: @offer.UserId
                        </small>

                    </div>

                </div>

            </div>
        }
    }
    else
    {
        <div class="alert alert-info">
            No offers yet. Be the first to make one!
        </div>
    }

</div>
<!-- Փոխում ենք սովորական հղումը history.back()-ով -->
<a asp-action="Index"
       class="btn btn-secondary mb-3">
    ← Back
</a>
@model FixMyCar.Web.Models.Post
@using FixMyCar.Web.Models
@using System.Security.Claims

@{
    ViewData["Title"] = Model.Title;
    var offers = ViewBag.Offers as List<Offer> ?? new List<Offer>();
    var currentUserIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
    int currentUserId = currentUserIdStr != null ? int.Parse(currentUserIdStr) : 0;
    bool isPostOwner = currentUserId == Model.UserId;
    bool isClosed = Model.ClosedAt != null;
}

<section class="post-details-page container py-4">
    @if (TempData["OfferSuccess"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["OfferSuccess"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Փակել"></button>
        </div>
    }
    @if (TempData["OfferError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["OfferError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Փակել"></button>
        </div>
    }

    <a href="javascript:history.back()" class="post-back-link">← Վերադառնալ հարցումներին</a>

    <article class="post-details-card">
        <header class="post-details-header">
            <div>
                <div class="post-details-labels">
                    <span class="post-category">@Model.Category?.Name</span>
                    <span class="post-state @(isClosed ? "closed" : "open")">@(isClosed ? "Փակված" : "Բաց")</span>
                </div>
                <h1>@Model.Title</h1>
            </div>
            <time>@Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")</time>
        </header>

        <div class="post-details-meta">
            <span>⌖ @Model.City</span>
            <span>◉ @Model.ViewCount դիտում</span>
            <span>Հրապարակել է՝ <a asp-controller="User" asp-action="Profile" asp-route-id="@Model.UserId">@Model.User?.UserName</a></span>
        </div>

        <p class="post-details-description">@Model.Description</p>

        @if (Model.Media != null && Model.Media.Any())
        {
            <div class="post-gallery">
                @foreach (var media in Model.Media.OrderBy(m => m.Order))
                {
                    if (media.Type == MediaType.Image)
                    {
                        <a href="@Url.Content(media.FilePath)" target="_blank" class="post-gallery-item">
                            <img src="@Url.Content(media.FilePath)" alt="@Model.Title" />
                        </a>
                    }
                }
            </div>
        }
    </article>

    <section class="offers-section">
        <header class="offers-heading">
            <div>
                <p class="eyebrow">Մասնագետների առաջարկներ</p>
                <h2>Առաջարկներ <span>@offers.Count</span></h2>
            </div>
            @if (!isClosed && !isPostOwner && User.Identity!.IsAuthenticated)
            {
                <a asp-controller="Offer" asp-action="Create" asp-route-postId="@Model.Id" class="btn request-publish">Առաջարկել գին</a>
            }
            else if (isClosed)
            {
                <span class="post-state closed">Հարցումը փակված է</span>
            }
            else if (!User.Identity!.IsAuthenticated)
            {
                <a asp-controller="User" asp-action="Login" class="btn post-secondary-action">Մուտք գործել՝ առաջարկ անելու համար</a>
            }
        </header>

        @if (offers.Any())
        {
            <div class="offers-list">
                @foreach (var offer in offers)
                {
                    var statusText = offer.Status switch
                    {
                        OfferStatus.Accepted => "Ընդունված",
                        OfferStatus.Rejected => "Մերժված",
                        _ => "Սպասման մեջ"
                    };
                    var statusClass = offer.Status switch
                    {
                        OfferStatus.Accepted => "accepted",
                        OfferStatus.Rejected => "rejected",
                        _ => "pending"
                    };

                    <article class="offer-details-card @statusClass">
                        <div class="offer-details-top">
                            <div>
                                <span class="offer-price">@offer.Currency @offer.Price</span>
                                <a asp-controller="User" asp-action="Profile" asp-route-id="@offer.UserId" class="offer-user">@(offer.User?.UserName ?? "Օգտատեր")</a>
                            </div>
                            <span class="offer-status @statusClass">@statusText</span>
                        </div>
                        <p>@offer.Message</p>
                        <footer>
                            <time>@offer.CreatedAt.ToString("dd MMM yyyy, HH:mm")</time>
                            @if (isPostOwner && offer.Status == OfferStatus.Pending && !isClosed)
                            {
                                <div class="offer-owner-actions">
                                    <form asp-controller="Offer" asp-action="Accept" method="post">
                                        <input type="hidden" name="id" value="@offer.Id" />
                                        <button type="submit" class="btn offer-accept" onclick="return confirm('Ընդունե՞լ այս առաջարկը։ Մյուս առաջարկները կմերժվեն, իսկ հարցումը կփակվի։')">Ընդունել</button>
                                    </form>
                                    <form asp-controller="Offer" asp-action="Decline" method="post">
                                        <input type="hidden" name="id" value="@offer.Id" />
                                        <button type="submit" class="btn offer-decline">Մերժել</button>
                                    </form>
                                </div>
                            }
                        </footer>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="offers-empty">Առաջարկներ դեռ չկան։ Եթե կարող եք օգնել, եղեք առաջինը։</div>
        }
    </section>
</section>

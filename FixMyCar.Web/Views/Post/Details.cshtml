@model FixMyCar.Web.Models.Post

@{
    ViewData["Title"] = "Post Details";
    var offers = ViewBag.Offers as List<FixMyCar.Web.Models.Offer>;
}

<h2>@Model.Title</h2>

<div class="card p-3 mb-4">

    <p><b>City:</b> @Model.City</p>
    <p><b>Description:</b> @Model.Description</p>
    <p><b>Category:</b> @Model.Category?.Name</p>

</div>

<hr />

<h3>Offers</h3>

@if (offers != null && offers.Any())
{
    @foreach (var offer in offers)
    {
        <div class="card mb-2 shadow-sm">

            <div class="card-body">

                <h5>@offer.Price $</h5>

                <p>@offer.Message</p>

                <small class="text-muted">
                    UserId: @offer.UserId
                </small>

            </div>

        </div>
    }
}
else
{
    <div class="alert alert-info">
        No offers yet for this post.
    </div>
}
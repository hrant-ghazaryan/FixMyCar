@using FixMyCar.Web.ViewModels
@model HomeViewModel

<section class="home-hero">
    <div class="container">
        <div class="hero-copy">
            <p class="eyebrow">Մեքենաների սպասարկման հարթակ</p>
            <h1>Գտեք ճիշտ մասնագետին<br />ձեր մեքենայի համար</h1>
            <p>Նկարագրեք խնդիրը, ստացեք առաջարկներ և ընտրեք հարմար տարբերակը։</p>
        </div>
        <form method="get" asp-controller="Home" asp-action="Index" class="home-search">
            <div class="search-field">
                <span>⌕</span>
                <input type="text" name="search" value="@Context.Request.Query["search"]" placeholder="Ի՞նչ խնդիր ունի մեքենան" />
            </div>
            <button type="submit" class="btn search-submit">Որոնել</button>
        </form>
    </div>
</section>

<section class="container category-section">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Արագ ընտրություն</p>
            <h2>Ընտրեք ծառայությունը</h2>
        </div>
        <a asp-controller="Category" asp-action="Index">Բոլոր կատեգորիաները →</a>
    </div>
    <div class="category-grid">
        @foreach (var category in Model.Categories.Where(c => c.ParentId == null))
        {
            <a asp-controller="Category" asp-action="SubCategories" asp-route-parentId="@category.Id" class="category-card">
                <span class="category-icon">🔧</span>
                <span>@category.Name</span>
            </a>
        }
    </div>
</section>

<section class="container posts-section">
    <div class="section-heading">
        <div>
            <p class="eyebrow">Թարմ ավելացված</p>
            <h2>Վերջին հարցումներ</h2>
        </div>
        <a asp-controller="Post" asp-action="Index">Դիտել բոլորը →</a>
    </div>
    <div class="row justify-content-center">
        <div class="col-xl-9 col-lg-10">

            @foreach (var post in Model.Posts)
            {
                var mainImage = post.Media?
                    .FirstOrDefault(m => m.IsMain)
                    ?? post.Media?.FirstOrDefault();

                @if (mainImage != null)
                {
                    <!-- POST WITH IMAGE -->

                    <article class="post-card">

                            <div class="d-flex gap-3 align-items-start">

                                <!-- LEFT: IMAGE -->
                                @if (mainImage != null)
                                {
                                    <a asp-action="Details"
                                           asp-route-id="@post.Id"
                                           class="flex-shrink-0">

                                        <img src="@Url.Content(mainImage.FilePath)"
                                             class="post-thumbnail" />
                                    </a>
                                }

                                <!-- RIGHT: CONTENT -->
                                <div class="flex-grow-1">

                                    <div class="d-flex justify-content-between align-items-start">

                                        <div>

                                            <span class="post-category">
                                                @post.Category?.Name
                                            </span>

                                            <h3 class="post-title">
                                                @post.Title
                                            </h3>

                                        </div>

                                        <small class="text-muted">
                                            @post.CreatedAt.ToString("dd MMM, HH:mm")
                                        </small>

                                    </div>

                                    <p class="post-description">
                                        @(post.Description.Length > 120
                                            ? post.Description[..120] + "..."
                                            : post.Description)
                                    </p>

                                    <div class="d-flex justify-content-between align-items-center">

                                        <div class="post-meta">
                                            📍 @post.City
                                        </div>

                                        <div class="d-flex gap-2">

                                            <a asp-controller="Post"
                                                asp-action="Details"
                                                   asp-route-id="@post.Id"
                                                   class="btn post-secondary-action">
                                                Դիտել
                                            </a>

                                            <a asp-controller="Offer"
                                                   asp-action="Create"
                                                   asp-route-postId="@post.Id"
                                                   class="btn post-primary-action">
                                                Առաջարկել գին
                                            </a>
                                            @if (User.Identity!.IsAuthenticated)
                                            {
                                                <form asp-controller="Favorite"
                                                      asp-action="Toggle"
                                                      method="post">

                                                    <input type="hidden"
                                                           name="postId"
                                                           value="@post.Id" />

                                                    <button type="submit"
                                                            class="btn post-secondary-action favorite-action">

                                                        @(Model.FavoritePostIds.Contains(post.Id) ? "♥" : "♡")

                                                    </button>

                                                </form>
                                            }

                                        </div>

                                    </div>

                                </div>

                            </div>

                    </article>
                }
                else
                {
                    <!-- POST WITHOUT IMAGE -->

                    <article class="post-card">

                            <div class="d-flex justify-content-between align-items-start">

                                <div>

                                    <span class="post-category">
                                        @post.Category?.Name
                                    </span>

                                    <h3 class="post-title">
                                        @post.Title
                                    </h3>

                                </div>

                                <small class="text-muted">
                                    @post.CreatedAt.ToString("dd MMM, HH:mm")
                                </small>

                            </div>

                            <p class="post-description">

                                @(post.Description.Length > 120
                                    ? post.Description[..120] + "..."
                                    : post.Description)

                            </p>

                            <div class="d-flex justify-content-between align-items-center">

                                <div class="post-meta">
                                    📍 @post.City
                                </div>

                                <div class="d-flex gap-2">

                                    <a asp-controller="Post"
                                        asp-action="Details"
                                           asp-route-id="@post.Id"
                                           class="btn post-secondary-action">
                                        Դիտել
                                    </a>

                                    <a asp-controller="Offer"
                                           asp-action="Create"
                                           asp-route-postId="@post.Id"
                                           class="btn post-primary-action">
                                        Առաջարկել գին
                                    </a>
                                    @if (User.Identity!.IsAuthenticated)
                                    {
                                        <form asp-controller="Favorite"
                                              asp-action="Toggle"
                                              method="post">

                                            <input type="hidden"
                                                   name="postId"
                                                   value="@post.Id" />

                                            <button type="submit"
                                                    class="btn post-secondary-action favorite-action">

                                                @(Model.FavoritePostIds.Contains(post.Id) ? "♥" : "♡")

                                            </button>

                                        </form>
                                    }
                                </div>

                            </div>

                    </article>
                }
            }

        </div>

    </div>

</section>
<partial name="_Pagination"
         model="Model.Pagination" />

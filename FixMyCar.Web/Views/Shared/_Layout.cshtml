<!DOCTYPE html>
<html lang="hy">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FixMyCar</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FixMyCar.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg site-navbar">
            <div class="container">
                <a class="navbar-brand p-0" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/FixMyCarInitial.png" class="logo-img" alt="FixMyCar" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Category" asp-action="Index">
                                Կատեգորիաներ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Post" asp-action="Index">
                                Հարցումներ
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item d-flex align-items-center me-2">

                                <a asp-controller="Favorite"
                                       asp-action="Index"
                                       class="favorite-btn"
                                       aria-label="Իմ ընտրյալները">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78Z"></path>
                                    </svg>
                                </a>

                            </li>
                        }
                        else
                        {
                            <li class="nav-item d-flex align-items-center me-2">

                                <a asp-controller="User"
                                       asp-action="Login"
                                       class="favorite-btn"
                                       aria-label="Մուտք գործել՝ ընտրյալները տեսնելու համար">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78Z"></path>
                                    </svg>
                                </a>

                            </li>
                        }
                        <li class="nav-item me-2 d-flex align-items-center">

                            <form method="get"
                                  asp-controller="Home"
                                  asp-action="Index"
                                  class="d-flex">

                                <div class="search-box">

                                    <input type="text"
                                           name="search"
                                           value="@Context.Request.Query["search"]"
                                           placeholder="Որոնել..."
                                           class="search-input" />

                                    <button type="submit" class="search-btn">
                                        🔍
                                    </button>

                                </div>

                            </form>

                        </li>
                        @if (User.Identity?.IsAuthenticated ?? false)
                        {
                            <li class="nav-item d-flex align-items-center me-2">
                                @await Html.PartialAsync("_Notifications")
                            </li>
                        }
                        <li class="nav-item d-flex align-items-center me-2">
                            <a asp-controller="Post"
                                   asp-action="Create"
                                   class="btn request-button">
                                + Տեղադրել հարցում
                            </a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link"
                                       asp-controller="User"
                                       asp-action="Profile">

                                    @(string.IsNullOrWhiteSpace(User.Identity?.Name)
                                        ? "User"
                                        : User.Identity.Name)

                                </a>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="User" asp-action="Logout" method="post">
                                    <button type="submit" class="nav-link border-0 bg-transparent">Ելք</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="User" asp-action="Login">
                                    Մուտք
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="User" asp-action="Register">
                                    Գրանցում
                                </a>
                            </li>
                        }

                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="site-content">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 FixMyCar · <a asp-area="" asp-controller="Home" asp-action="Privacy">Գաղտնիություն</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.0/signalr.js"></script>

    <script>
            if ('scrollRestoration' in history) {
                history.scrollRestoration = 'manual';
            }

            window.addEventListener("pagehide", function () {
                sessionStorage.setItem(
                    window.location.pathname + "_scroll",
                    window.scrollY
                );
            });

            window.addEventListener("pageshow", function () {

                const scroll = sessionStorage.getItem(
                    window.location.pathname + "_scroll"
                );

                if (scroll !== null) {
                    window.scrollTo(0, parseInt(scroll));
                }

            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>

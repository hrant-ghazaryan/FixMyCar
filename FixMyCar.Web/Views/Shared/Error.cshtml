@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <h1 class="text-danger">Something went wrong.</h1>
    <p class="lead">We could not process your request. Please try again later.</p>

    @if (Model.ShowRequestId)
    {
        <p class="text-muted">
            Request ID: <code>@Model.RequestId</code>
        </p>
    }

    <a asp-controller="Home" asp-action="Index" class="btn btn-dark">Return to home page</a>
</div>

@model FixMyCar.Web.ViewModels.PaginationViewModel

@if (Model.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">

            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                           href="@Model.BaseUrl?page=@(Model.CurrentPage - 1)">
                        ← Prev
                    </a>
                </li>
            }

            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link"
                           href="@Model.BaseUrl?page=@i">
                        @i
                    </a>
                </li>
            }

            @if (Model.CurrentPage < Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link"
                           href="@Model.BaseUrl?page=@(Model.CurrentPage + 1)">
                        Next →
                    </a>
                </li>
            }

        </ul>
    </nav>
}
@model List<FixMyCar.Web.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<h2 class="mb-3">Categories</h2>

<!-- ✅ ADMIN CREATE BUTTON -->
@if (User.IsInRole("Admin"))
{
    <div class="mb-3 text-end">
        <a asp-action="Create" class="btn btn-success">
            + Create New Category
        </a>
    </div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>

            @if (User.IsInRole("Admin"))
            {
                <th>Parent</th>
                <th>Actions</th>
            }
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>

                <!-- Category Name -->
                <td>
                    @item.Name
                </td>

                @if (User.IsInRole("Admin"))
                {
                    <!-- Parent only for admin -->
                    <td>
                        @(item.Parent?.Name ?? "-")
                    </td>

                    <!-- Admin actions -->
                    <td>
                        <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning">
                            Edit
                        </a>

                        <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger">
                            Delete
                        </a>
                    </td>
                }

            </tr>
        }
    </tbody>
</table>
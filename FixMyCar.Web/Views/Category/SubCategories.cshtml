@model List<FixMyCar.Web.Models.Category>

<h3 class="mb-4">Sub Categories</h3>

<a asp-action="Index" class="btn btn-light mb-3">
    ← Back
</a>

<div class="row">

    @foreach (var cat in Model)
    {
        <div class="col-md-4 mb-3">

            <a asp-controller="Post"
                   asp-action="ByCategory"
                   asp-route-categoryId="@cat.Id"
                   class="text-decoration-none">

                <div class="card p-3 text-center shadow-sm">

                    <h6>@cat.Name</h6>

                </div>

            </a>

        </div>
    }

</div>
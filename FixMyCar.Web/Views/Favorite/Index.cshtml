@using FixMyCar.Web.Models
@model List<Favorite>

@{
    ViewData["Title"] = "Իմ ընտրյալները";
}

<section class="favorites-page container py-4">
    <header class="favorites-heading">
        <div class="favorites-heading-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35 10.55 20.03C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09A6.01 6.01 0 0 1 16.5 3C19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35Z" /></svg>
        </div>
        <div>
            <p class="eyebrow">Ձեր պահպանած հարցումները</p>
            <h1>Իմ ընտրյալները</h1>
            <p>Վերադարձեք հետաքրքրող հարցումներին ցանկացած ժամանակ։</p>
        </div>
    </header>

    @if (!Model.Any())
    {
        <div class="favorites-empty">
            <div class="favorites-empty-icon">♡</div>
            <h2>Ընտրյալներում դեռ ոչինչ չկա</h2>
            <p>Հետաքրքրող հարցումները պահպանեք սրտիկի միջոցով, որպեսզի հեշտ գտնեք դրանք հետո։</p>
            <a asp-controller="Home" asp-action="Index" class="btn auth-submit">Դիտել հարցումները</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var item in Model)
            {
                if (item.Post is not { } post)
                {
                    continue;
                }

                var mainImage = post.Media?.FirstOrDefault(m => m.IsMain) ?? post.Media?.FirstOrDefault();
                <div class="col-md-6 col-lg-4">
                    <article class="favorite-card">
                        @if (mainImage != null)
                        {
                            <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="favorite-image-link">
                                <img src="@Url.Content(mainImage.FilePath)" class="favorite-image" alt="@post.Title" />
                            </a>
                        }
                        <div class="favorite-card-body">
                            <div class="favorite-card-top">
                                <span class="post-category">@post.Category?.Name</span>
                                <form asp-controller="Favorite" asp-action="Toggle" method="post">
                                    <input type="hidden" name="postId" value="@post.Id" />
                                    <button type="submit" class="favorite-remove-button" aria-label="Հեռացնել ընտրյալներից">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35 10.55 20.03C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09A6.01 6.01 0 0 1 16.5 3C19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35Z" /></svg>
                                    </button>
                                </form>
                            </div>
                            <h2>@post.Title</h2>
                            <p>@(post.Description.Length > 112 ? post.Description[..112] + "..." : post.Description)</p>
                            <footer>
                                <span>@post.City</span>
                                <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="btn post-secondary-action">Դիտել</a>
                            </footer>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</section>

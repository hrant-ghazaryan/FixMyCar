@model FixMyCar.Web.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Գրանցում";
}

<section class="auth-page">
    <div class="auth-card">
        <div class="auth-heading">
            <p class="eyebrow">FixMyCar</p>
            <h1>Ստեղծեք հաշիվ</h1>
            <p>Ստացեք առաջարկներ ձեր մեքենայի հարցման համար։</p>
        </div>

        <form asp-action="Register" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label asp-for="DisplayName" class="form-label">Անուն և ազգանուն</label>
                <input asp-for="DisplayName" class="form-control" placeholder="Օր.` Արամ Մարտիրոսյան" autocomplete="name" />
                <span asp-validation-for="DisplayName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Էլ․ փոստ</label>
                <input asp-for="Email" class="form-control" placeholder="name@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PhoneNumber" class="form-label">Հեռախոսահամար <span>(ոչ պարտադիր)</span></label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="+374 XX XX XX XX" autocomplete="tel" />
                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Գաղտնաբառ</label>
                <input asp-for="Password" class="form-control" placeholder="Առնվազն 8 նիշ" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label">Կրկնել գաղտնաբառը</label>
                <input asp-for="ConfirmPassword" class="form-control" placeholder="Կրկնեք գաղտնաբառը" autocomplete="new-password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn auth-submit w-100">Գրանցվել</button>
        </form>

        <p class="auth-switch">Արդեն ունե՞ք հաշիվ։ <a asp-action="Login">Մուտք գործել</a></p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@using FixMyCar.Web.Models
@model FixMyCar.Web.Models.User

@{
    ViewData["Title"] = ViewBag.IsOwnProfile == true ? "Իմ էջը" : $"{Model.UserName}-ի էջը";
    var userPosts = ViewBag.UserPosts as List<Post> ?? new List<Post>();
    var userOffers = ViewBag.UserOffers as List<Offer> ?? new List<Offer>();
    var reviews = ViewBag.Reviews as List<Review> ?? new List<Review>();
    double averageRating = ViewBag.AverageRating ?? 0.0;
    bool isOwnProfile = ViewBag.IsOwnProfile == true;
    bool canLeaveReview = ViewBag.CanLeaveReview == true;
}

<section class="profile-page container py-4">
    @if (TempData["ReviewError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ReviewError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Փակել"></button>
        </div>
    }

    <header class="profile-header">
        <div class="profile-avatar">@(!string.IsNullOrWhiteSpace(Model.UserName) ? Model.UserName[0].ToString().ToUpper() : "U")</div>
        <div class="profile-details">
            <div class="profile-name-row">
                <h1>@(string.IsNullOrWhiteSpace(Model.UserName) ? "Օգտատեր" : Model.UserName)</h1>
                <span class="profile-role">@Model.Role</span>
            </div>
            <div class="profile-rating">
                @if (averageRating > 0)
                {
                    <span>★ @averageRating.ToString("0.0")</span>
                    <small>@reviews.Count կարծիք</small>
                }
                else
                {
                    <small>Դեռ կարծիքներ չկան</small>
                }
            </div>
            <div class="profile-contact">
                <span>@Model.Email</span>
                <span>@(Model.PhoneNumber ?? "Հեռախոսահամարը նշված չէ")</span>
                <span>Միացել է @Model.CreatedAt.ToString("dd MMM yyyy")</span>
            </div>
        </div>
        @if (isOwnProfile)
        {
            <a asp-controller="User" asp-action="Settings" class="btn profile-settings-button">Կարգավորումներ</a>
        }
    </header>

    <div class="row g-4">
        <div class="@(canLeaveReview ? "col-lg-8" : "col-12")">
            <nav class="profile-tabs" role="tablist">
                <button class="active" id="posts-tab" data-bs-toggle="pill" data-bs-target="#posts" type="button" role="tab" aria-controls="posts" aria-selected="true">
                    Հարցումներ <span>@userPosts.Count</span>
                </button>
                <button id="offers-tab" data-bs-toggle="pill" data-bs-target="#offers" type="button" role="tab" aria-controls="offers" aria-selected="false">
                    Առաջարկներ <span>@userOffers.Count</span>
                </button>
                <button id="reviews-tab" data-bs-toggle="pill" data-bs-target="#reviews" type="button" role="tab" aria-controls="reviews" aria-selected="false">
                    Կարծիքներ <span>@reviews.Count</span>
                </button>
            </nav>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="posts" role="tabpanel" aria-labelledby="posts-tab">
                    @if (!userPosts.Any())
                    {
                        <div class="profile-empty">Դեռ հարցումներ չկան։</div>
                    }
                    else
                    {
                        @foreach (var post in userPosts)
                        {
                            <article class="profile-list-card">
                                <div class="profile-card-top">
                                    <div>
                                        <span class="post-category">@post.Category?.Name</span>
                                        <h2>@post.Title</h2>
                                    </div>
                                    <small>@post.CreatedAt.ToString("dd MMM yyyy")</small>
                                </div>
                                <p>@(post.Description.Length > 150 ? post.Description[..150] + "..." : post.Description)</p>
                                <footer>
                                    <span>@post.City</span>
                                    <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" class="btn post-secondary-action">Դիտել</a>
                                </footer>
                            </article>
                        }
                    }
                </div>

                <div class="tab-pane fade" id="offers" role="tabpanel" aria-labelledby="offers-tab">
                    @if (!userOffers.Any())
                    {
                        <div class="profile-empty">Դեռ առաջարկներ չկան։</div>
                    }
                    else
                    {
                        @foreach (var offer in userOffers)
                        {
                            <article class="profile-list-card">
                                <div class="profile-card-top">
                                    <div>
                                        <span class="offer-price">$@offer.Price</span>
                                        <h2>@(offer.Post?.Title ?? "Հեռացված հարցում")</h2>
                                    </div>
                                </div>
                                <p>@offer.Message</p>
                                @if (offer.Post != null)
                                {
                                    <footer><a asp-controller="Post" asp-action="Details" asp-route-id="@offer.PostId" class="btn post-secondary-action">Դիտել հարցումը</a></footer>
                                }
                            </article>
                        }
                    }
                </div>

                <div class="tab-pane fade" id="reviews" role="tabpanel" aria-labelledby="reviews-tab">
                    @if (!reviews.Any())
                    {
                        <div class="profile-empty">Դեռ կարծիքներ չկան։</div>
                    }
                    else
                    {
                        @foreach (var review in reviews)
                        {
                            <article class="profile-list-card review-list-card">
                                <div class="profile-card-top">
                                    <div>
                                        <a asp-controller="User" asp-action="Profile" asp-route-id="@review.ReviewerId" class="reviewer-name">@review.Reviewer.UserName</a>
                                        <div class="review-stars">@for (int i = 1; i <= 5; i++) { <span>@(i <= review.Rating ? "★" : "☆")</span> }</div>
                                    </div>
                                    <small>@review.CreatedAt.ToString("dd MMM yyyy")</small>
                                </div>
                                <p>@review.Comment</p>
                            </article>
                        }
                    }
                </div>
            </div>
        </div>

        @if (canLeaveReview)
        {
            <aside class="col-lg-4">
                <div class="review-form-card">
                    <h2>Կարծիք թողնել</h2>
                    <p>@Model.UserName-ի հետ աշխատանքի մասին</p>
                    <form asp-controller="User" asp-action="AddReview" method="post">
                        <input type="hidden" name="targetUserId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label">Գնահատական</label>
                            <div class="rating-stars">
                                <input type="radio" id="star5" name="rating" value="5" required /><label for="star5">★</label>
                                <input type="radio" id="star4" name="rating" value="4" /><label for="star4">★</label>
                                <input type="radio" id="star3" name="rating" value="3" /><label for="star3">★</label>
                                <input type="radio" id="star2" name="rating" value="2" /><label for="star2">★</label>
                                <input type="radio" id="star1" name="rating" value="1" /><label for="star1">★</label>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="comment" class="form-label">Կարծիք</label>
                            <textarea id="comment" name="comment" rows="4" class="form-control" placeholder="Կիսվեք ձեր փորձով..." maxlength="500" required></textarea>
                        </div>
                        <button type="submit" class="btn auth-submit w-100">Ուղարկել կարծիքը</button>
                    </form>
                </div>
            </aside>
        }
    </div>
</section>

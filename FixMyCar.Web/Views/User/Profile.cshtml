@model FixMyCar.Web.Models.User

@{
    ViewData["Title"] = "Profile";
    var posts = ViewBag.UserPosts as List<FixMyCar.Web.Models.Post>;
}

<h2>My Profile</h2>

<div class="card border-0 shadow-sm rounded-4 mb-4">

    <div class="card-body p-4">

        <h3 class="fw-bold mb-1">
            @(string.IsNullOrWhiteSpace(Model.UserName)
                ? "User"
                : Model.UserName)
        </h3>

        <p class="text-muted mb-3">
            @Model.Email
        </p>

        <div class="row small">

            <div class="col-md-6">
                📞 @(Model.PhoneNumber ?? "Not specified")
            </div>

            <div class="col-md-6 text-md-end">
                📅 @Model.CreatedAt.ToString("dd MMM yyyy")
            </div>

        </div>

    </div>

</div>

<h4 class="fw-semibold mb-3">
    My Posts
</h4>

@if (posts != null && posts.Any())
{
    @foreach (var post in posts)
    {
        <div class="card border-0 shadow-sm rounded-4 mb-3">

            <div class="card-body">

                <div class="d-flex justify-content-between">

                    <div>

                        <span class="badge bg-light text-dark border mb-2">
                            @post.Category?.Name
                        </span>

                        <h5 class="fw-bold mb-1">
                            @post.Title
                        </h5>

                        <div class="text-muted small">
                            📍 @post.City
                        </div>

                    </div>

                    <div class="d-flex gap-2 align-items-start">

                        <a asp-controller="Post"
                               asp-action="Details"
                               asp-route-id="@post.Id"
                               class="btn btn-outline-dark btn-sm">
                            View
                        </a>

                        <a asp-controller="Post"
                               asp-action="Edit"
                               asp-route-id="@post.Id"
                               class="btn btn-outline-secondary btn-sm">
                            Edit
                        </a>

                    </div>

                </div>

            </div>

        </div>
    }
}
else
{
    <div class="text-muted">
        No posts yet.
    </div>
}

<h4 class="fw-semibold mt-5 mb-3">
    My Offers
</h4>

@if (@Model.Offers != null && @Model.Offers.Any())
{
    @foreach (var offer in @Model?.Offers)
    {
        <div class="card border-0 shadow-sm rounded-4 mb-3">

            <div class="card-body">

                <div class="d-flex justify-content-between">

                    <div>

                        <h5 class="fw-bold mb-1">
                            $@offer.Price
                        </h5>

                        <div class="text-muted mb-2">
                            @offer.Post?.Title
                        </div>

                        <small class="text-muted">
                            @offer.CreatedAt.ToString("dd MMM yyyy")
                        </small>

                    </div>

                    <div class="d-flex gap-2">

                        <a asp-controller="Offer"
                               asp-action="Details"
                               asp-route-id="@offer.Id"
                               class="btn btn-outline-dark btn-sm">
                            View
                        </a>

                        <a asp-controller="Offer"
                               asp-action="Edit"
                               asp-route-id="@offer.Id"
                               class="btn btn-outline-secondary btn-sm">
                            Edit
                        </a>

                    </div>

                </div>

            </div>

        </div>
    }
}
else
{
    <div class="text-muted">
        No offers yet.
    </div>
}
@{
    ViewData["Title"] = "Ծանուցումներ";
}

<section class="notifications-page container py-4">
    <header class="notifications-heading">
        <div>
            <p class="eyebrow">FixMyCar</p>
            <h1>Ծանուցումներ</h1>
            <p>Տեսեք ձեր հարցումների և առաջարկների վերջին թարմացումները։</p>
        </div>
        <button type="button" class="btn notifications-read-all" id="markAllAsReadBtn">Նշել բոլորը կարդացված</button>
    </header>

    <div id="notificationsList" class="notifications-list" aria-live="polite">
        <div class="notifications-loading">
            <div class="spinner-border" role="status"><span class="visually-hidden">Բեռնվում է...</span></div>
            <span>Բեռնվում են ծանուցումները...</span>
        </div>
    </div>
</section>

<script>
    async function loadAllNotifications() {
        try {
            const response = await fetch('/api/notification/all');
            const notifications = await response.json();
            displayAllNotifications(notifications);
        } catch (err) {
            console.error('Error loading notifications:', err);
            document.getElementById('notificationsList').innerHTML = '<div class="notifications-error">Չհաջողվեց բեռնել ծանուցումները։ Կրկին փորձեք քիչ հետո։</div>';
        }
    }

    function displayAllNotifications(notifications) {
        const list = document.getElementById('notificationsList');

        if (!notifications.length) {
            list.innerHTML = '<div class="notifications-empty"><span>✓</span><h2>Նոր ծանուցումներ չկան</h2><p>Նոր առաջարկների կամ հարցումների թարմացումների դեպքում դրանք կհայտնվեն այստեղ։</p></div>';
            return;
        }

        list.innerHTML = notifications.map(n => `
            <article class="notification-list-item ${!n.isRead ? 'unread' : ''}" data-id="${n.id}">
                <div class="notification-status" aria-hidden="true">${!n.isRead ? '●' : ''}</div>
                <div class="notification-content">
                    <div class="notification-list-item-header">
                        <h2>${escapeHtml(n.title)}</h2>
                        <time>${formatFullTime(n.createdAt)}</time>
                    </div>
                    <p>${escapeHtml(n.message)}</p>
                    <div class="notification-list-item-actions">
                        ${!n.isRead ? `<button type="button" class="btn notification-mark-read mark-read-btn" data-id="${n.id}">Նշել կարդացված</button>` : ''}
                        <button type="button" class="btn notification-delete delete-btn" data-id="${n.id}">Ջնջել</button>
                    </div>
                </div>
                <button type="button" class="notification-close btn-close" data-id="${n.id}" aria-label="Ջնջել ծանուցումը"></button>
            </article>
        `).join('');

        document.querySelectorAll('.mark-read-btn').forEach(btn => btn.addEventListener('click', () => markNotificationAsRead(Number(btn.dataset.id))));
        document.querySelectorAll('.delete-btn, .notification-close').forEach(btn => btn.addEventListener('click', () => deleteNotification(Number(btn.dataset.id))));
    }

    function formatFullTime(date) {
        return new Date(date).toLocaleString('hy-AM', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    async function markNotificationAsRead(notificationId) {
        try {
            await fetch(`/api/notification/mark-as-read/${notificationId}`, { method: 'POST' });
            loadAllNotifications();
        } catch (err) { console.error('Error marking notification as read:', err); }
    }

    async function deleteNotification(notificationId) {
        try {
            await fetch(`/api/notification/${notificationId}`, { method: 'DELETE' });
            loadAllNotifications();
        } catch (err) { console.error('Error deleting notification:', err); }
    }

    document.getElementById('markAllAsReadBtn').addEventListener('click', async () => {
        try {
            await fetch('/api/notification/mark-all-as-read', { method: 'POST' });
            loadAllNotifications();
        } catch (err) { console.error('Error marking all as read:', err); }
    });

    document.addEventListener('DOMContentLoaded', loadAllNotifications);
</script>
